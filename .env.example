# Discord bot token (required). Keep this secret — never commit a real token.
DISCORD_TOKEN=

# Optional: register slash commands to a single guild for instant updates.
# Leave empty to register commands globally (can take up to an hour to appear).
DISCORD_GUILD_ID=

# Optional: comma-separated role IDs; holding any one lets a member use the
# bot's commands. If empty, every member may use the commands.
REQUIRED_ROLE_IDS=

# Optional: path to the SQLite database (default: data/schedule.db).
DATABASE_PATH=data/schedule.db

# Optional: how often the scheduler checks for due messages (default: 15s).
POLL_INTERVAL=15s
